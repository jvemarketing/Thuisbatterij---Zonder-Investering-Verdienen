<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="utf-8">
<title>Energiecrisis kan 10 jaar duren — wat doe jij? · Vaste Lasten Onderzoek</title>

<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="Hoogleraar waarschuwt: energiecrisis kan vijf tot tien jaar duren. Check in 2 minuten hoeveel jij kunt besparen — en maak kans op een prijs t.w.v. €500.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800;900&display=swap">
<style>
  :root {
    --purple:#14447C;
    --purple-deep:#0E3460;
    --purple-soft:#eef3f9;
    --purple-line:#d4e0ee;
    --lime:#FF8300;
    --lime-deep:#E66F00;
    --warn:#E2001A;
    --t1:#1a1330;
    --t2:#4a3f63;
    --t3:#8a7da5;
  }
  *,*::before,*::after { box-sizing:border-box; }
  html,body { margin:0; padding:0; overflow-x:hidden; }
  body {
    font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
    color:var(--t1);
    background:#ffffff;
    -webkit-font-smoothing:antialiased;
    line-height:1.6;
  }
  a { color:inherit; }

  /* ============ URGENCY BAR ============ */
  .urgency {
    background:var(--purple);
    color:#fff;
    font-family:'Outfit',Arial,sans-serif;
    font-weight:700;
    font-size:13px;
    letter-spacing:0.3px;
    position:sticky; top:0; z-index:50;
    border-bottom:2px solid var(--lime);
  }
  .urgency-inner {
    max-width:1200px; margin:0 auto;
    padding:10px 20px;
    display:flex; align-items:center; justify-content:space-between; gap:16px;
  }
  .urgency .left { display:flex; align-items:center; gap:10px; min-width:0; }
  .pulse-dot {
    width:10px; height:10px; border-radius:50%; background:var(--warn);
    box-shadow:0 0 0 0 rgba(226,0,26,0.6);
    animation: pulse 1.6s infinite;
    flex:0 0 auto;
  }
  @keyframes pulse {
    0% { box-shadow:0 0 0 0 rgba(226,0,26,0.6); }
    70% { box-shadow:0 0 0 10px rgba(226,0,26,0); }
    100% { box-shadow:0 0 0 0 rgba(226,0,26,0); }
  }
  .urgency .label {
    background:var(--warn); color:#fff;
    font-size:10px; font-weight:900; letter-spacing:1.5px;
    padding:3px 8px; border-radius:4px;
    text-transform:uppercase;
    flex:0 0 auto;
  }
  .urgency .msg {
    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  }
  .urgency .msg b { color:var(--lime); }
  .urgency a.cta-mini {
    background:linear-gradient(0deg, #13C406 0%, #5BFF4D 100%); color:#ffffff;
    text-decoration:none;
    font-weight:900; font-size:13px;
    padding:10px 16px; border-radius:12px;
    white-space:nowrap;
    transition:transform .15s ease;
    flex:0 0 auto;
    display:inline-flex; align-items:center; gap:6px;
    font-family:'Outfit',Arial,sans-serif;
    box-shadow:0 3px 8px rgba(27,242,12,0.4), 0 1px 3px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.25);
  }
  .urgency a.cta-mini:hover { transform:translateY(-1px); }

  /* ============ SITE BAR (looks like a news site header) ============ */
  .sitebar {
    background:#fff; border-bottom:1px solid #ececec;
  }
  .sitebar-inner {
    max-width:1200px; margin:0 auto; padding:14px 20px;
    display:flex; align-items:center; justify-content:space-between;
  }
  .brand {
    font-family:'Outfit',Arial,sans-serif; font-weight:900;
    font-size:18px; color:var(--purple); letter-spacing:-0.3px;
    display:flex; align-items:center; gap:8px; text-decoration:none;
  }
  .brand .bolt {
    width:26px; height:26px; background:var(--lime); border-radius:50%;
    display:inline-flex; align-items:center; justify-content:center;
    color:var(--purple); font-size:16px; font-weight:900;
  }
  .sitebar .breadcrumbs {
    font-size:12px; color:var(--t3); letter-spacing:0.5px;
  }
  .sitebar .breadcrumbs span.cat { color:var(--purple); font-weight:700; }
  .ad-tag {
    font-size:10px; letter-spacing:1.5px; color:var(--t3);
    text-transform:uppercase; font-weight:700;
    border:1px solid #e3dded; padding:3px 7px; border-radius:4px;
  }

  /* ============ ARTICLE ============ */
  article {
    max-width:720px; margin:0 auto; padding:32px 24px 80px;
  }
  .kicker {
    font-family:'Inter',Arial,sans-serif;
    font-size:11px; font-weight:700; letter-spacing:2px;
    text-transform:uppercase; color:var(--warn);
    display:flex; align-items:center; gap:8px; margin-bottom:14px;
  }
  .kicker::before {
    content:""; width:18px; height:2px; background:var(--warn); display:inline-block;
  }
  h1 {
    font-family:'Outfit',Arial,sans-serif;
    font-weight:900;
    font-size:clamp(34px, 5.4vw, 52px);
    line-height:1.06;
    letter-spacing:-1px;
    color:var(--purple);
    margin:0 0 18px;
    text-wrap:balance;
  }
  h1 .hl {
    background:linear-gradient(180deg, transparent 65%, var(--lime) 65%);
    padding:0 4px;
  }
  .subhead {
    font-family:'Inter',Arial,sans-serif;
    font-size:19px; line-height:1.5; color:var(--t2);
    margin:0 0 24px;
    text-wrap:pretty;
  }
  .byline {
    display:flex; align-items:center; gap:12px;
    padding:14px 0; border-top:1px solid #ececec; border-bottom:1px solid #ececec;
    font-size:13px; color:var(--t3);
    margin-bottom:28px;
  }
  .byline b { color:var(--t1); }

  /* ============ HERO IMAGE HEADER ============ */
  .hero-image-header {
    margin:0 -24px 28px;
    width:calc(100% + 48px);
    position:relative;
    aspect-ratio: 16 / 9;
    background:#14447C;
    overflow:hidden;
  }
  .hero-image-header .bg {
    position:absolute; inset:0;
    background-image:url("/vaste-lasten/img/energie-crisis-bg.png");
    background-size:cover;
    background-position:center;
  }
  .hero-image-header .scrim {
    position:absolute; inset:0;
    background:
      linear-gradient(180deg, rgba(23,10,38,0.05) 0%, rgba(23,10,38,0.20) 40%, rgba(23,10,38,0.78) 78%, rgba(23,10,38,0.94) 100%),
      linear-gradient(90deg, rgba(23,10,38,0.35) 0%, rgba(23,10,38,0) 45%);
  }
  .hero-image-header .content {
    position:absolute; left:0; right:0; bottom:0;
    padding:28px 32px 28px;
    color:#fff;
  }
  .hero-image-header .kicker {
    color:#ff6d6d; margin-bottom:12px;
  }
  .hero-image-header .kicker::before { background:#ff6d6d; }
  .hero-image-header h1 {
    color:#fff;
    font-size:clamp(28px, 4.4vw, 42px);
    line-height:1.08;
    margin:0;
    text-shadow:0 2px 16px rgba(0,0,0,0.45);
    max-width:640px;
  }
  .hero-image-header h1 .hl {
    background:var(--lime);
    color:#ffffff;
    padding:2px 10px;
    border-radius:6px;
    white-space:nowrap;
    text-shadow:none;
    display:inline-block;
    margin:2px 0;
  }
  .hero-image-header .subline {
    font-family:'Outfit',Arial,sans-serif;
    font-weight:600;
    font-size:clamp(15px, 1.8vw, 19px);
    line-height:1.4;
    color:#d6e4f5;
    margin:14px 0 0;
    text-shadow:0 2px 12px rgba(0,0,0,0.35);
    max-width:560px;
  }
  .hero-image-header .warn-tag {
    display:inline-block; background:var(--warn); color:#fff;
    font-size:10px; font-weight:900; letter-spacing:1.5px;
    padding:3px 8px; border-radius:4px;
    margin-bottom:14px; text-transform:uppercase;
    box-shadow:0 4px 12px rgba(226,0,26,0.4);
  }
  @media (max-width:720px) {
    .hero-image-header { aspect-ratio: 4 / 3; }
    .hero-image-header .bg { background-size:cover; background-position:center top; }
    .hero-image-header .content { padding:22px 22px 22px; }
    .hero-image-header h1 { font-size:26px; }
  }

  /* ============ HERO VISUAL (news-style) ============ */
  .hero-visual {
    margin:0 -24px 28px;
    width:calc(100% + 48px);
    position:relative;
    background:linear-gradient(180deg, #0E3460 0%, #14447C 60%, #1B5499 100%);
    overflow:hidden;
    border-radius:0;
  }
  .hero-visual::before {
    content:""; position:absolute; inset:0;
    background:
      radial-gradient(circle at 10% 20%, rgba(226,0,26,0.18), transparent 40%),
      radial-gradient(circle at 90% 80%, rgba(27,242,12,0.12), transparent 50%);
  }
  .hero-visual .inner {
    position:relative; padding:36px 28px 32px;
    color:#fff;
  }
  .hero-stat-grid {
    display:grid; grid-template-columns:repeat(3, 1fr); gap:14px;
    margin-top:18px;
  }
  .hero-stat {
    background:rgba(255,255,255,0.06);
    border:1px solid rgba(255,255,255,0.10);
    border-radius:12px;
    padding:14px 14px 12px;
  }
  .hero-stat .n {
    font-family:'Outfit',Arial,sans-serif; font-weight:900;
    font-size:30px; line-height:1; color:var(--lime);
    letter-spacing:-0.5px;
  }
  .hero-stat .n .unit { font-size:18px; color:#fff; opacity:.7; margin-left:2px; }
  .hero-stat .l {
    font-size:11px; color:#c5d6ec; letter-spacing:0.3px; margin-top:8px; line-height:1.4;
  }
  .hero-headline-strip {
    font-family:'Outfit',Arial,sans-serif;
    font-weight:800; font-size:18px; line-height:1.3; color:#fff;
    margin:0 0 4px;
  }
  .hero-headline-strip .warn-tag {
    display:inline-block; background:var(--warn); color:#fff;
    font-size:11px; font-weight:900; letter-spacing:1.5px;
    padding:2px 8px; border-radius:4px; vertical-align:middle;
    margin-right:8px; text-transform:uppercase;
  }
  .hero-sub {
    font-size:13px; color:#c5d6ec; margin-top:2px;
  }

  /* ============ BODY COPY ============ */
  article p {
    font-size:17px; line-height:1.65; color:var(--t1);
    margin:0 0 18px;
  }
  article p.lead {
    font-size:19px; line-height:1.55; color:var(--t1); font-weight:500;
  }
  article p .hl {
    background:linear-gradient(180deg, transparent 65%, var(--lime) 65%);
    padding:0 2px;
  }
  article strong { color:var(--purple); font-weight:700; }
  h2 {
    font-family:'Outfit',Arial,sans-serif; font-weight:900;
    font-size:28px; line-height:1.18; letter-spacing:-0.5px;
    color:var(--purple); margin:36px 0 14px;
    text-wrap:balance;
  }
  h2 .warn { color:var(--warn); }

  /* ============ PULL QUOTE ============ */
  .pullquote {
    margin:28px 0 28px;
    padding:24px 24px 20px;
    background:var(--purple-soft);
    border-left:4px solid var(--lime);
    border-radius:0 12px 12px 0;
  }
  .pullquote .q {
    font-family:'Outfit',Arial,sans-serif; font-weight:700;
    font-size:22px; line-height:1.35; color:var(--purple);
    letter-spacing:-0.3px;
    margin:0 0 12px;
    text-wrap:balance;
  }
  .pullquote .q::before { content:"\201C"; color:var(--lime); margin-right:4px; }
  .pullquote .q::after { content:"\201D"; color:var(--lime); }
  .pullquote .attr {
    display:flex; align-items:center; gap:10px;
    font-size:13px; color:var(--t2);
  }
  .pullquote .attr .ava {
    width:32px; height:32px; border-radius:50%;
    background:var(--purple); color:var(--lime);
    display:flex; align-items:center; justify-content:center;
    font-family:'Outfit',Arial,sans-serif; font-weight:800; font-size:12px;
  }
  .pullquote .attr .src-logo {
    height:22px; width:auto; display:block; flex:0 0 auto;
  }
  .pullquote .attr b { color:var(--purple); }

  /* ============ CHECK LIST ============ */
  .danger-list {
    list-style:none; padding:0; margin:8px 0 24px;
  }
  .danger-list li {
    display:flex; align-items:flex-start; gap:12px;
    padding:12px 0; border-bottom:1px solid #f0eef5;
    font-size:16px; line-height:1.5;
  }
  .danger-list li:last-child { border-bottom:0; }
  .danger-list .icon {
    width:28px; height:28px; border-radius:50%;
    background:#fde8eb; color:var(--warn);
    display:flex; align-items:center; justify-content:center;
    font-weight:900; font-size:15px; flex:0 0 auto;
    font-family:'Outfit',Arial,sans-serif;
  }
  .danger-list b { color:var(--purple); }

  /* ============ MID-ARTICLE CTA CARD ============ */
  .cta-card {
    margin:36px 0;
    background:var(--purple);
    border-radius:18px;
    padding:32px 28px;
    color:#fff;
    position:relative; overflow:hidden;
    text-align:center;
  }
  .cta-card::before {
    content:""; position:absolute; top:-40px; right:-40px;
    width:200px; height:200px; border-radius:50%;
    background:radial-gradient(circle, rgba(27,242,12,0.22), transparent 65%);
  }
  .cta-card .eyebrow {
    display:inline-block;
    font-family:'Inter',Arial,sans-serif;
    font-size:10px; font-weight:700; letter-spacing:2px;
    text-transform:uppercase; color:var(--lime);
    border:1px solid rgba(27,242,12,0.45);
    padding:4px 10px; border-radius:20px;
    margin-bottom:14px;
  }
  .cta-card h3 {
    font-family:'Outfit',Arial,sans-serif; font-weight:900;
    font-size:28px; line-height:1.15; letter-spacing:-0.5px;
    color:#fff; margin:0 0 10px;
    text-wrap:balance;
  }
  .cta-card h3 .lime { color:var(--lime); }
  .cta-card .body {
    font-size:15px; line-height:1.55; color:#c5d6ec;
    margin:0 0 22px;
  }
  .cta-btn {
    display:inline-flex; align-items:center; justify-content:center; gap:12px;
    width:100%; max-width:460px; box-sizing:border-box;
    background:linear-gradient(0deg, #13C406 0%, #5BFF4D 100%); color:#ffffff;
    font-family:'Outfit',Arial,sans-serif; font-weight:900;
    font-size:22px; letter-spacing:0.2px;
    padding:22px 34px; border-radius:22px;
    text-decoration:none;
    box-shadow:0 9px 20px rgba(27,242,12,0.45), 0 3px 7px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.25);
    transition:transform .15s ease, box-shadow .2s ease;
    border:0;
  }
  .cta-btn .bolt { font-size:20px; line-height:1; }
  .cta-btn:hover {
    transform:translateY(-2px);
    box-shadow:0 12px 25px rgba(27,242,12,0.55), 0 4px 9px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.3);
  }
  .cta-btn .arrow {
    font-weight:900; font-size:22px;
    transition:transform .15s ease;
  }
  .cta-btn:hover .arrow { transform:translateX(3px); }
  .cta-card .btn-wrap { text-align:center; }
  .cta-card .trust-row {
    display:flex; flex-wrap:wrap; gap:8px 18px;
    margin-top:18px;
    justify-content:center;
    font-size:12px; color:#c5d6ec;
  }
  .cta-card .trust-row span { display:inline-flex; align-items:center; gap:6px; }
  .cta-card .trust-row span::before {
    content:"\2713"; color:var(--lime); font-weight:900;
  }

  /* ============ POLL ============ */
  .poll {
    background:#fff; border:1.5px solid var(--purple-line);
    border-radius:14px; padding:22px 22px 18px;
    margin:28px 0;
  }
  .poll .label {
    font-size:11px; font-weight:700; letter-spacing:2px;
    color:var(--purple); text-transform:uppercase; margin-bottom:10px;
  }
  .poll h4 {
    font-family:'Outfit',Arial,sans-serif; font-weight:800;
    font-size:18px; line-height:1.3; color:var(--purple);
    margin:0 0 14px;
  }
  .poll .options { display:grid; gap:8px; }
  .poll .opt {
    text-align:left; cursor:pointer;
    background:var(--purple-soft); border:1.5px solid var(--purple-line);
    border-radius:10px; padding:12px 14px;
    font-family:'Inter',Arial,sans-serif; font-size:14px; font-weight:500;
    color:var(--t1);
    display:flex; align-items:center; justify-content:space-between; gap:10px;
    transition:all .15s ease;
    position:relative; overflow:hidden;
  }
  .poll .opt:hover { border-color:var(--lime); background:#fff; }
  .poll .opt .bar {
    position:absolute; left:0; top:0; bottom:0;
    background:rgba(27,242,12,0.22);
    width:0%; transition:width .6s cubic-bezier(.4,1.6,.6,1);
    z-index:0;
  }
  .poll .opt .txt, .poll .opt .pct {
    position:relative; z-index:1;
  }
  .poll .opt .pct {
    font-family:'Outfit',Arial,sans-serif; font-weight:800; font-size:13px;
    color:var(--purple); opacity:0; transition:opacity .3s ease .3s;
  }
  .poll.voted .opt .pct { opacity:1; }
  .poll.voted .opt { cursor:default; }
  .poll.voted .opt.picked { border-color:var(--lime); background:#fff; }
  .poll .meta { font-size:11px; color:var(--t3); margin-top:12px; }

  /* ============ FINAL CTA SECTION ============ */
  .final-cta {
    background:var(--purple);
    padding:48px 28px 64px;
    color:#fff;
    text-align:center;
    position:relative; overflow:hidden;
  }
  .final-cta::before {
    content:""; position:absolute; inset:0; pointer-events:none;
    background:
      radial-gradient(circle at 20% 30%, rgba(27,242,12,0.12), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(226,0,26,0.08), transparent 50%);
  }
  .final-cta .eyebrow {
    font-size:11px; font-weight:700; letter-spacing:2.5px;
    text-transform:uppercase; color:var(--lime);
    margin-bottom:14px; position:relative;
  }
  .final-cta h2 {
    color:#fff; font-size:36px; line-height:1.1;
    margin:0 0 12px; position:relative;
    letter-spacing:-0.5px;
  }
  .final-cta h2 .lime { color:var(--lime); }
  .final-cta p {
    color:#c5d6ec; font-size:16px; line-height:1.55;
    margin:0 auto 24px; max-width:480px; position:relative;
  }
  .final-cta .stats {
    display:flex; justify-content:center; flex-wrap:wrap; gap:18px 32px;
    margin-top:32px; position:relative;
  }
  .final-cta .stats .s {
    text-align:center;
  }
  .final-cta .stats .n {
    font-family:'Outfit',Arial,sans-serif; font-weight:900;
    font-size:24px; color:var(--lime); line-height:1;
  }
  .final-cta .stats .l {
    font-size:11px; color:#c5d6ec; letter-spacing:0.5px;
    margin-top:6px; text-transform:uppercase;
  }

  /* ============ FOOTER ============ */
  footer {
    background:var(--purple-deep); color:#8aa3c4;
    padding:28px 24px; text-align:center;
    font-size:12px; line-height:1.7;
  }
  footer a { color:#bcd0e8; text-decoration:underline; }

  /* ============ STICKY MOBILE CTA ============ */
  .sticky-mobile {
    position:fixed; left:0; right:0; bottom:0;
    background:#fff; border-top:1.5px solid var(--purple-line);
    padding:10px 14px calc(10px + env(safe-area-inset-bottom));
    z-index:40;
    display:none;
    box-shadow:0 -10px 30px rgba(26,15,43,0.15);
  }
  .sticky-mobile a {
    display:flex; align-items:center; justify-content:center; gap:10px;
    text-align:center;
    background:linear-gradient(0deg, #13C406 0%, #5BFF4D 100%); color:#ffffff;
    font-family:'Outfit',Arial,sans-serif; font-weight:900;
    font-size:18px; padding:18px 14px; border-radius:18px;
    text-decoration:none;
    box-shadow:0 6px 14px rgba(27,242,12,0.45), 0 2px 5px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.25);
  }
  .sticky-mobile .sub {
    font-size:11px; color:var(--t3); margin-top:6px; text-align:center;
  }
  @media (max-width:720px) {
    .sticky-mobile { display:block; }
    body { padding-bottom:90px; }
    .urgency .msg-long { display:none; }
    .hero-stat-grid { grid-template-columns:repeat(3, 1fr); gap:8px; }
    .hero-stat { padding:10px 10px 9px; }
    .hero-stat .n { font-size:22px; }
    .hero-stat .l { font-size:10px; }
    h1 { font-size:32px; }
    h2 { font-size:24px; }
    .cta-card { padding:24px 20px; }
    .cta-card h3 { font-size:22px; }
    .pullquote .q { font-size:18px; }
    .final-cta h2 { font-size:28px; }
    .sitebar .breadcrumbs { display:none; }
  }
  @media (min-width:721px) {
    .urgency .msg-short { display:none; }
  }
</style>

