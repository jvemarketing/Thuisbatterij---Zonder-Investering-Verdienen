<script>
  // Auto-format postcode while typing (e.g. "1234AB" → "1234 AB")
  document.querySelectorAll('.postcode-input').forEach(function(input) {
    input.addEventListener('input', function(e) {
      var val = e.target.value.toUpperCase().replace(/[^0-9A-Z]/g, '');
      if (val.length > 4) {
        val = val.slice(0, 4) + ' ' + val.slice(4, 6);
      }
      e.target.value = val;
      e.target.classList.remove('error');
      var errorMsg = e.target.parentElement.querySelector('.postcode-error-msg');
      if (errorMsg) errorMsg.classList.remove('show');
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        var btn = e.target.parentElement.querySelector('.postcode-button');
        if (btn) checkPostcode(btn);
      }
    });
  });

  function checkPostcode(button) {
    var widget = button.closest('.postcode-check');
    var input = widget.querySelector('.postcode-input');
    var errorMsg = widget.querySelector('.postcode-error-msg');

    var postcode = input.value.trim().toUpperCase().replace(/\s+/g, '');

    // Dutch postcode: 4 digits (first not 0) + 2 letters
    var regex = /^[1-9][0-9]{3}[A-Z]{2}$/;

    if (!regex.test(postcode)) {
      input.classList.add('error');
      if (errorMsg) errorMsg.classList.add('show');
      input.focus();
      return false;
    }

    button.disabled = true;
    button.style.opacity = '0.7';
    button.innerHTML = '<span>⚡</span> Even geduld...';

    window.location.href = '/thuisbatterij/flow?pc=' + encodeURIComponent(postcode) + '&source=prelander';
    return true;
  }
</script>

