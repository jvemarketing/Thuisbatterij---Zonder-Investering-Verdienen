<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Thuisbatterij: €60-75 Per Maand Verdienen — Met Of Zonder Zonnepanelen</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --orange: #FF6B1A;
    --orange-dark: #E85A0C;
    --orange-light: #FFF4EC;
    --navy: #0A1F3D;
    --navy-mid: #152E54;
    --navy-light: #E8EDF5;
    --red-alert: #DC2626;
    --green-check: #10B981;
    --ink: #0A1F3D;
    --white: #ffffff;
    --gray-light: #F5F7FA;
    --gray-mid: #E0E4EB;
    --muted: #4A5568;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: #ffffff;
    color: #0A1F3D;
    line-height: 1.65;
    font-size: 17px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
    text-rendering: optimizeLegibility;
  }

  /* ── ALERT BAR ── */
  .alert-bar {
    background: var(--red-alert);
    color: white;
    text-align: center;
    padding: 10px 16px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.3px;
  }
  .alert-bar::before {
    content: '●';
    color: white;
    margin-right: 8px;
    animation: pulse 1.5s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(180deg, #0A1F3D 0%, #152E54 60%, #1A3866 100%);
    color: white;
    padding: 90px 24px 70px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 100%, rgba(255,107,26,0.15) 0%, transparent 70%);
  }
  .hero > * { position: relative; }
  .hero-tag {
    display: inline-block;
    background: var(--orange);
    color: white;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 50px;
    margin-bottom: 28px;
  }
  .hero h1 {
    font-size: clamp(2rem, 6vw, 3.8rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.025em;
    max-width: 780px;
    margin: 0 auto 24px;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--orange);
  }
  .hero-sub {
    font-size: 1.15rem;
    font-weight: 300;
    max-width: 560px;
    margin: 0 auto 40px;
    opacity: 0.88;
    line-height: 1.7;
  }
  .hero-proof {
    margin-top: 36px;
    font-size: 0.88rem;
    opacity: 0.7;
    font-style: italic;
  }
  .hero-proof strong { color: var(--orange); font-style: normal; }

  /* ── LAYOUT ── */
  .container {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── INTRO ── */
  .intro {
    padding: 64px 24px 40px;
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }
  .intro h2 {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 24px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .intro-lead {
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 24px;
    line-height: 1.6;
    text-align: left;
    border-left: 4px solid var(--orange);
    padding-left: 20px;
  }
  .intro p { margin-bottom: 18px; color: var(--navy); text-align: left; }
  .intro-question {
    font-size: 1.35rem;
    color: var(--orange-dark);
    margin-top: 36px;
    font-weight: 700;
  }

  /* ── DUAL BENEFIT BANNER ── */
  .dual-benefit {
    background: var(--navy);
    color: white;
    border-radius: 12px;
    padding: 36px 32px;
    margin: 40px 0;
    position: relative;
    overflow: hidden;
  }
  .dual-benefit::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 100% 0%, rgba(255,107,26,0.15) 0%, transparent 70%);
  }
  .dual-benefit > * { position: relative; }
  .dual-benefit h3 {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
    color: var(--orange);
    text-align: center;
  }
  .dual-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 20px;
  }
  .dual-option {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,107,26,0.3);
    border-radius: 8px;
    padding: 20px;
  }
  .dual-option .label {
    font-size: 0.78rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--orange);
    font-weight: 700;
    margin-bottom: 10px;
  }
  .dual-option .title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .dual-option p { font-size: 0.92rem; line-height: 1.6; opacity: 0.88; }
  @media (max-width: 600px) {
    .dual-grid { grid-template-columns: 1fr; }
  }

  /* ── BLISSY-STYLE LISTICLE ROW ── */
  .list-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    padding: 40px 0;
    border-bottom: 1px solid var(--gray-mid);
  }
  .list-row:last-of-type { border-bottom: none; }

  .list-row.layout-left .row-image { order: 1; }
  .list-row.layout-left .row-text { order: 2; }
  .list-row.layout-right .row-text { order: 1; }
  .list-row.layout-right .row-image { order: 2; }

  .row-text h2 {
    font-size: clamp(1.3rem, 2.6vw, 1.65rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--navy);
    margin-bottom: 16px;
    display: flex;
    gap: 10px;
    align-items: baseline;
  }
  .row-text h2 .num {
    font-size: 1.6rem;
    color: var(--orange);
    font-weight: 900;
    flex-shrink: 0;
  }
  .row-text h2 .num::after {
    content: '.';
    color: var(--orange);
  }
  .row-text p {
    margin-bottom: 14px;
    font-size: 0.98rem;
    color: var(--navy);
    line-height: 1.65;
  }
  .row-text p:last-child { margin-bottom: 0; }
  .row-text strong { color: var(--navy); font-weight: 700; }

  @media (max-width: 720px) {
    .list-row {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 32px 0;
    }
    .list-row.layout-left .row-image,
    .list-row.layout-right .row-image { order: 1; }
    .list-row.layout-left .row-text,
    .list-row.layout-right .row-text { order: 2; }
  }

  /* ── INLINE QUOTE ── */
  .inline-quote {
    background: var(--navy-light);
    border-left: 3px solid var(--orange);
    border-radius: 0 6px 6px 0;
    padding: 14px 18px;
    margin: 16px 0;
    font-style: italic;
    font-size: 0.92rem;
    color: var(--navy);
  }
  .inline-quote .attribution {
    margin-top: 8px;
    font-style: normal;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--orange-dark);
    letter-spacing: 0.5px;
  }

  /* ── OFFICIAL QUOTE ── */
  .official-quote {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    color: white;
    border-radius: 6px;
    padding: 20px 22px;
    margin: 16px 0;
    border-left: 3px solid var(--orange);
  }
  .official-quote .badge {
    display: inline-block;
    background: var(--orange);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 50px;
    margin-bottom: 10px;
  }
  .official-quote .text {
    font-style: italic;
    font-weight: 500;
    font-size: 0.98rem;
    line-height: 1.55;
    margin-bottom: 10px;
    color: white;
  }
  .official-quote .source {
    font-size: 0.76rem;
    opacity: 0.7;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  /* ── DOUBT BUSTER ── */
  .doubt-inline {
    background: var(--orange-light);
    border-left: 3px solid var(--orange);
    border-radius: 0 6px 6px 0;
    padding: 14px 18px;
    margin: 16px 0;
    font-size: 0.9rem;
  }
  .doubt-inline .q {
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 6px;
    display: flex;
    gap: 6px;
  }
  .doubt-inline .q::before { content: '🤔'; flex-shrink: 0; }
  .doubt-inline .a {
    color: var(--navy);
    font-weight: 500;
    display: flex;
    gap: 6px;
  }
  .doubt-inline .a::before { content: '✅'; flex-shrink: 0; }

  /* ── INLINE STATS ── */
  .inline-stats {
    display: flex;
    gap: 10px;
    margin: 16px 0;
    flex-wrap: wrap;
  }
  .inline-stat {
    flex: 1;
    min-width: 100px;
    background: var(--navy);
    color: white;
    border-radius: 6px;
    padding: 12px 10px;
    text-align: center;
  }
  .inline-stat .val {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--orange);
    display: block;
    line-height: 1.2;
  }
  .inline-stat .lbl {
    font-size: 0.7rem;
    opacity: 0.85;
    line-height: 1.35;
    margin-top: 4px;
  }

  /* ── URGENCY BOX ── */
  .urgency-box {
    background: #FFF5F5;
    border: 2px solid var(--red-alert);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 16px 0;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .urgency-box .icon { font-size: 1.4rem; flex-shrink: 0; }
  .urgency-box h4 {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--red-alert);
    margin-bottom: 4px;
  }
  .urgency-box p {
    margin: 0 !important;
    font-size: 0.85rem !important;
    color: var(--navy);
    line-height: 1.5 !important;
  }

  /* ── CTA BLOCK ── */
  .cta-full {
    background: linear-gradient(135deg, #0A1F3D 0%, #152E54 100%);
    color: white;
    padding: 60px 24px;
    margin: 60px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-full::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 80% 20%, rgba(255,107,26,0.15) 0%, transparent 70%);
  }
  .cta-full > * { position: relative; }
  .cta-full h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-full p {
    font-size: 1rem;
    opacity: 0.9;
    max-width: 560px;
    margin: 0 auto 32px;
  }
  .cta-full .sub { margin-top: 16px; font-size: 0.82rem; opacity: 0.65; font-style: italic; }
  .cta-checks {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin: 24px auto 8px;
    flex-wrap: wrap;
    font-size: 0.88rem;
    max-width: 600px;
  }
  .cta-checks span { display: flex; align-items: center; gap: 6px; }
  .cta-checks span::before { content: '✓'; color: var(--green-check); font-weight: 900; }

  /* ── FINAL VERDICT ── */
  .verdict {
    background: var(--orange-light);
    border: 2px solid var(--orange);
    border-radius: 12px;
    padding: 36px 32px;
    margin: 40px 0;
  }
  .verdict h3 {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    color: var(--navy);
    text-align: center;
  }
  .verdict ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 620px;
    margin: 0 auto;
  }
  .verdict ul li {
    display: flex;
    gap: 10px;
    font-size: 0.97rem;
    color: var(--navy);
  }
  .verdict ul li::before { content: '✓'; flex-shrink: 0; color: var(--orange); font-weight: 900; font-size: 1.1rem; }

  /* ── POSTCODE WIDGET ── */
  .postcode-check {
    background: #ffffff;
    border-radius: 14px;
    padding: 28px 28px 24px;
    max-width: 480px;
    margin: 0 auto;
    box-shadow: 0 12px 40px rgba(0,0,0,0.25), 0 4px 12px rgba(0,0,0,0.15);
    text-align: left;
  }
  .postcode-header {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 8px;
  }
  .postcode-header .pin { color: #FFC107; font-size: 1.3rem; line-height: 1.1; flex-shrink: 0; }
  .postcode-header h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
    margin: 0;
    line-height: 1.3;
  }
  .postcode-sub {
    color: #6B7280;
    font-size: 0.92rem;
    margin: 0 0 18px;
    line-height: 1.5;
  }
  .postcode-input {
    width: 100%;
    padding: 16px 20px;
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--navy);
    background: #ffffff;
    border: 1.5px solid #D1D5DB;
    border-radius: 10px;
    outline: none;
    margin-bottom: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .postcode-input::placeholder { color: #9CA3AF; font-weight: 600; letter-spacing: 2px; }
  .postcode-input:focus {
    border-color: var(--orange);
    box-shadow: 0 0 0 3px rgba(255,107,26,0.15);
  }
  .postcode-input.error {
    border-color: var(--red-alert);
    box-shadow: 0 0 0 3px rgba(220,38,38,0.15);
    animation: shake 0.4s ease;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }
  .postcode-button {
    width: 100%;
    background: var(--orange);
    color: white;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1.02rem;
    padding: 16px 20px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(255,107,26,0.35);
  }
  .postcode-button:hover {
    background: var(--orange-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(255,107,26,0.45);
  }
  .postcode-button:active { transform: translateY(0); }
  .postcode-footer {
    margin-top: 12px;
    text-align: center;
    color: #9CA3AF;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .postcode-footer::before { content: '🔒'; font-size: 0.9rem; }
  .postcode-error-msg {
    display: none;
    background: #FEF2F2;
    color: var(--red-alert);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 8px 12px;
    border-radius: 6px;
    margin-bottom: 12px;
    text-align: center;
  }
  .postcode-error-msg.show { display: block; }
  .cta-full .postcode-check { margin-top: 8px; }

  /* ── FOOTER ── */
  footer {
    background: var(--navy);
    color: rgba(255,255,255,0.55);
    text-align: center;
    padding: 36px 24px;
    font-size: 0.82rem;
  }
  footer a { color: var(--orange); text-decoration: none; font-weight: 600; }
  .footer-links { margin-bottom: 12px; }
  .footer-links a { color: rgba(255,255,255,0.6); margin: 0 10px; font-weight: 400; }
  .footer-links a:hover { color: var(--orange); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero > * { animation: fadeUp 0.7s ease both; }
  .hero-tag { animation-delay: 0.1s; }
  .hero h1 { animation-delay: 0.25s; }
  .hero-sub { animation-delay: 0.4s; }
  .hero .postcode-check { animation-delay: 0.55s; }
  .hero-proof { animation-delay: 0.7s; }
</style>

