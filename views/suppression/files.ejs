<%
  const fmt = (d) =>
    d ? new Date(d).toLocaleString('nl-NL', { dateStyle: 'short', timeStyle: 'short' }) : '—';
  const fmtSize = (b) => b < 1024 ? `${b} B` : `${(b / 1024).toFixed(1)} KB`;
%>
<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<title>Suppression bestanden</title>
<style>
  body { font-family: sans-serif; padding: 2rem; background: #f5f5f5; color: #1a1a1a; }
  h1 { font-size: 1.3rem; margin-bottom: 1.5rem; }
  table { border-collapse: collapse; width: 100%; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
  th { background: #0d1f3c; color: #fff; text-align: left; padding: 10px 14px; font-size: .85rem; }
  td { padding: 10px 14px; font-size: .85rem; border-bottom: 1px solid #ebebeb; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #fafafa; }
  a { color: #f26b00; font-weight: 600; text-decoration: none; }
  a:hover { text-decoration: underline; }
</style>
</head>
<body>
<h1>Suppression bestanden</h1>
<table>
  <thead>
    <tr>
      <th>Bestand</th>
      <th>Grootte</th>
      <th>Aangemaakt</th>
      <th>Gedownload</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% if (files.length === 0) { %>
      <tr><td colspan="5" style="text-align:center;color:#888">Geen bestanden gevonden</td></tr>
    <% } else { %>
      <% files.forEach(f => { %>
        <tr>
          <td><%= f.filename %></td>
          <td><%= fmtSize(f.size) %></td>
          <td><%= fmt(f.createdAt) %></td>
          <td><%= fmt(f.downloadedAt) %></td>
          <td><a href="/api/suppression/download/<%= encodeURIComponent(f.filename) %>">Download</a></td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
</body>
</html>
